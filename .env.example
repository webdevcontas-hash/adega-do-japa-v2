# Banco de dados (SQLite local)
DATABASE_URL="file:./dev.db"

# URL pública da aplicação (usada para montar a notification_url do webhook do Mercado Pago)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Mercado Pago — Access Token da conta da adega (Pix)
MERCADOPAGO_ACCESS_TOKEN=""

# Mercado Pago — Secret de assinatura do webhook (painel de notificações). Opcional, mas recomendado em produção.
MERCADOPAGO_WEBHOOK_SECRET=""

# WhatsApp da adega para receber a notificação de pedido pago (formato: 55DDDNUMERO)
WHATSAPP_STORE_NUMBER="5511999999999"

# Senha simples para acessar o painel de pedidos (/dashboard)
DASHBOARD_PASSWORD="adega123"

# Segredo para assinar as sessões (dashboard + login do cliente, HMAC). String aleatória longa (>32 chars).
SESSION_SECRET=""

# Login com Google (OAuth) — OPCIONAL. Sem isto, a "conta leve" no dispositivo continua funcionando;
# o botão "Continuar com Google" só aparece quando as duas variáveis abaixo estão preenchidas.
# 1) https://console.cloud.google.com/apis/credentials -> Criar credenciais -> ID do cliente OAuth -> App Web
# 2) Em "URIs de redirecionamento autorizados", adicione:  <NEXT_PUBLIC_BASE_URL>/api/auth/google/callback
#    (ex.: http://localhost:3501/api/auth/google/callback)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Horário de funcionamento (formato 24h, 0-23). Pode cruzar a meia-noite (ex: abre 18h, fecha 3h)
BUSINESS_HOURS_OPEN="18"
BUSINESS_HOURS_CLOSE="3"
